<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Leave a Review – Proctoclinic</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f6f7f9;
      margin: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .card {
      background: white;
      padding: 28px;
      border-radius: 16px;
      max-width: 420px;
      width: 92%;
      text-align: center;
      box-shadow: 0 12px 30px rgba(0,0,0,0.12);
    }

    h1 {
      font-size: 20px;
      margin-bottom: 10px;
    }

    p {
      font-size: 14px;
      color: #555;
      line-height: 1.5;
      margin-bottom: 18px;
    }

    .btn {
      display: block;
      padding: 14px;
      margin-top: 10px;
      border-radius: 10px;
      text-decoration: none;
      font-weight: bold;
      transition: 0.2s ease;
    }

    .primary {
      background: #1a73e8;
      color: white;
    }

    .primary:hover {
      background: #1558b0;
    }

    .secondary {
      background: #f1f3f4;
      color: #333;
    }

    .secondary:hover {
      background: #e5e7ea;
    }

    .hint {
      font-size: 12px;
      color: #777;
      margin-top: 14px;
      line-height: 1.4;
    }

    .stars {
      font-size: 18px;
      margin-bottom: 8px;
    }
  </style>
</head>

<body>

  <div class="card">

    <div class="stars">⭐⭐⭐⭐⭐</div>

    <h1>Thank you for visiting Proctoclinic</h1>

    <p>
      Your feedback helps other patients choose the right care and helps us improve our services.
      If you had a positive experience, please leave a quick Google review.
    </p>

    <!-- PRIMARY (best available Google trigger) -->
    <a class="btn primary"
       href="https://search.google.com/local/writereview?placeid=ChIJr8lC3l0BskAR0W3z3Yl9l6A"
       target="_blank">
       Leave a Google Review
    </a>

    <!-- FALLBACK (always works) -->
    <a class="btn secondary"
       href="https://www.google.com/maps/search/?api=1&query=Proctoclinic+Bucuresti"
       target="_blank">
       Open Google Reviews Page
    </a>

    <div class="hint">
      Tip: After opening Google, tap “Reviews” → “Write a review”.
    </div>

  </div>

  <script>
    // Optional: lightweight mobile optimization hint (no tracking)
    if (/Android|iPhone/i.test(navigator.userAgent)) {
      document.querySelector('.hint').innerText =
        "Tip: Tap 'Reviews' → 'Write a review' after opening Google.";
    }
  </script>

</body>
</html>
